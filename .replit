modules = ["nodejs-20", "web", "python-3.11", "postgresql-16"]
run = "npm run dev"
hidden = [".config", ".git", "generated-icon.png", "node_modules", "dist"]

[nix]
channel = "stable-24_05"
packages = ["jq", "chromium", "dig", "psmisc"]

[deployment]
deploymentTarget = "autoscale"
build = ["npm", "run", "build"]
run = ["npm", "run", "start"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "test-privacy"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[[workflows.workflow]]
name = "test-privacy"
author = "agent"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npx tsx test/communications-transcribe-privacy.test.ts && npx tsx test/communications-transcribe-recovery.test.ts && npx tsx test/session-transcribe-privacy.test.ts && npx tsx test/assessment-report-privacy.test.ts && npx tsx test/daily-schedule-email-privacy.test.ts && npx tsx test/daily-schedule-email-idempotency.test.ts && npx tsx test/daily-schedule-email-preference.test.ts && npx tsx test/notification-preferences-mute.test.ts && npx tsx test/notification-specific-users.test.ts && npx tsx test/deferred-summary-email.test.ts && npx tsx test/quiet-hours-suppression.test.ts"

[[ports]]
localPort = 5000
externalPort = 80

[agent]
integrations = ["javascript_stripe:1.0.0", "javascript_openai_ai_integrations:1.0.0"]

[objectStorage]
defaultBucketID = "replit-objstore-f52068a8-0421-4eb6-8b0c-2d09231aa6b1"

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 180000
